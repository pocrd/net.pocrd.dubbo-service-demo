# 环境变量配置示例文件
# 复制此文件为 .env.prod 或 .env.test 并填写实际值

# Nacos 注册中心配置
DUBBO_REGISTRY_ADDRESS=nacos://nacos-server:8848
DUBBO_CONFIG_CENTER=nacos://nacos-server:8848
DUBBO_METADATA_REPORT_ADDRESS=nacos://nacos-server:8848

# MySQL 数据库配置
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=demo
MYSQL_USERNAME=root
MYSQL_PASSWORD=your_password_here
